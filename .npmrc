# Supply-chain delay: refuse package versions younger than 30 days (minutes).
minimum-release-age=43200
# Our own package — exempt from the quarantine so a fresh release installs now.
minimum-release-age-exclude[]=@bilikaz/code-reviewer
auto-install-peers=true
strict-peer-dependencies=false
# Flat node_modules: electron-builder can't follow pnpm's isolated symlinks when packaging.
node-linker=hoisted
