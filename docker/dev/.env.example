# Copy to .env (alongside docker-compose.yml) and adjust. `.env` is gitignored.

# ─── MariaDB ────────────────────────────────────────────────
DATABASE_ROOT_PASSWORD=kn-root
DATABASE_NAME=knowledge
DATABASE_USER=kn
DATABASE_PASSWORD=kn

# Connection string the knowledge api uses (compose-internal hostname `db`).
DATABASE_URL=mysql://kn:kn@db:3306/knowledge

# ─── API ────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Auth ───────────────────────────────────────────────────
# Change JWT_SECRET for anything beyond local dev. TTLs in seconds.
JWT_SECRET=dev-insecure-change-me
ACCESS_TTL=900
REFRESH_TTL=2592000

# ─── Knowledgebase (OpenSearch + embeddings) ────────────────
OPENSEARCH_URL=http://opensearch:9200
EMBEDDING_HF_MODEL=intfloat/multilingual-e5-small
EMBEDDING_BASE_URL=http://embeddings/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBED_DIM=384
EMBED_CHUNK_CHARS=2000
# For BGE-M3: EMBED_DIM=1024 and blank the prefixes (EMBED_QUERY_PREFIX= / EMBED_PASSAGE_PREFIX=).

# ─── Inngest (async ingestion) ──────────────────────────────
# SIGNING_KEY must be even-length hex; it gates the api's /inngest webhook.
INNGEST_EVENT_KEY=dev-event-key
INNGEST_SIGNING_KEY=deadbeefdeadbeefdeadbeefdeadbeef
INNGEST_DEV=1
INNGEST_BASE_URL=http://inngest:8288
INNGEST_SERVE_ORIGIN=http://knowledge:3000
